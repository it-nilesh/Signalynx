{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Signalynx": {
    "Transport": {
      "Provider": "in-memory",
      "RabbitMQ": {
        "QueueName": "orders"
      },
      "AzureServiceBus": {
        "EntityPath": "orders"
      },
      "AmazonSqs": {
        "QueueUrl": "orders"
      },
      "Kafka": {
        "Topic": "orders"
      }
    }
  },
  "AllowedHosts": "*"
}
